    "nock": "^12.0.3",
    "oxfmt": "^0.4.0",
    "oxlint": "^0.15.14",
    "sinon": "=1.10.2",
    "typescript": "^5.9.2",
    "webpack": "^4.42.1",
    "webpack-cli": "^3.3.11"
