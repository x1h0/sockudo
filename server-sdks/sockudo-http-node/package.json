    "tweetnacl": "^1.0.0",
    "tweetnacl-util": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^14.14.6",
    "@types/node-fetch": "^2.5.7",
    "expect.js": "=0.3.1",
