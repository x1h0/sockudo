    "pbkdf2": "^3.1.5",
    "qs": "^6.14.0",
    "sha.js": "^2.4.12",
    "tar": "^6.2.1"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "local-test": "npx mocha 'tests/integration/**/*.js'",
    "test": "npx mocha 'tests/{integration,remote}/**/*.js'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prelocal-test": "npm run build",
    "pretest": "npm run build",
    "lint": "npx oxlint --config .oxlintrc.json src tests examples index.d.ts && npx oxfmt --check src tests examples index.d.ts package.json tsconfig.json .oxlintrc.json",
    "format": "npx oxfmt src tests examples index.d.ts package.json tsconfig.json .oxlintrc.json"
  },
  "keywords": [
    "sockudo",
    "websockets",
    "realtime"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sockudo/sockudo-http-node.git"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt"
  ],
  "main": "dist/sockudo.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  }
}
