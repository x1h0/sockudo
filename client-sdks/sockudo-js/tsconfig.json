{
  "compilerOptions": {
    "sourceMap": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "node",
    "declaration": false,
    "removeComments": true,
    "skipLibCheck": true,
    "baseUrl": "src",
    "rootDir": ".",
    "paths": {
      "runtime": ["runtimes/web/runtime.ts"],
      "core/*": ["core/*"],
      "isomorphic/*": ["runtimes/isomorphic/*"],
      "web/*": ["runtimes/web/*"],
      "worker/*": ["runtimes/worker/*"],
      "react-native/*": ["runtimes/react-native/*"],
      "node/*": ["runtimes/node/*"],
      "*": ["*", "runtimes/*"],
    },
    "lib": ["ScriptHost", "DOM", "ES2022"],
    "types": ["bun-types", "node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
  },
  "exclude": ["node_modules", "dist", "types", "sockudo-js"],
  "include": ["src/**/*.ts", "src/d.ts/**/*.d.ts", "test/**/*.ts", "index.ts"],
}
