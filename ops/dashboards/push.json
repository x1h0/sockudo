{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": { "limit": 100, "matchAny": false, "tags": [], "type": "dashboard" },
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Push SLOs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(sockudo_push_publish_acceptance_duration_seconds_bucket{app=~\"$app\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "title": "Acceptance p99",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(sockudo_push_dispatch_duration_seconds_bucket{provider=~\"$provider\",app=~\"$app\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "title": "Dispatch p99",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sockudo_push_publish_log_lag_seconds",
          "refId": "A"
        }
      ],
      "title": "Publish Log Lag",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider) (sockudo_push_circuit_breaker_state{provider=~\"$provider\"})",
          "refId": "A"
        }
      ],
      "title": "Circuit Breakers Open",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "panels": [],
      "title": "Admission And Planning",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (result) (rate(sockudo_push_publish_accepted_total{app=~\"$app\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(sockudo_push_quota_acceptance_rejections_total{app=~\"$app\"}[5m]))",
          "legendFormat": "quota_rejected",
          "refId": "B"
        }
      ],
      "title": "Publish Acceptance Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(sockudo_push_planner_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "planner p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(sockudo_push_fanout_size_bucket{app=~\"$app\"}[5m])) by (le))",
          "legendFormat": "fanout p99",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(sockudo_push_channel_publish_total[5m]))",
          "legendFormat": "channel publishes",
          "refId": "C"
        }
      ],
      "title": "Planner And Fanout",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "panels": [],
      "title": "Dispatch And Providers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider,status) (rate(sockudo_push_dispatched_total{provider=~\"$provider\",app=~\"$app\"}[5m]))",
          "legendFormat": "{{provider}} {{status}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider) (sockudo_push_dispatch_inflight{provider=~\"$provider\",app=~\"$app\"})",
          "legendFormat": "{{provider}} inflight",
          "refId": "B"
        }
      ],
      "title": "Dispatch Outcomes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider) (rate(sockudo_push_delivery_jobs_emitted_total{provider=~\"$provider\",app=~\"$app\"}[5m]))",
          "legendFormat": "{{provider}} emitted",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (provider) (sockudo_push_delivery_jobs_lag_seconds{provider=~\"$provider\"})",
          "legendFormat": "{{provider}} lag",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider) (sockudo_push_worker_pool_busy{provider=~\"$provider\"}) / clamp_min(sum by (provider) (sockudo_push_worker_pool_size{provider=~\"$provider\"}), 1)",
          "legendFormat": "{{provider}} busy ratio",
          "refId": "C"
        }
      ],
      "title": "Delivery Queues And Workers",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "panels": [],
      "title": "Fairness And Backpressure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider,app) (rate(sockudo_push_wfq_dispatched_total{provider=~\"$provider\",app=~\"$app\"}[5m]))",
          "legendFormat": "{{provider}} {{app}} dispatched",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (provider,app) (sockudo_push_wfq_starvation_seconds{provider=~\"$provider\",app=~\"$app\"})",
          "legendFormat": "{{provider}} {{app}} starvation",
          "refId": "B"
        }
      ],
      "title": "Weighted Fair Queueing",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
