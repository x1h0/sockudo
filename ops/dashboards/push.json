        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (app) (sockudo_push_quota_consumed_acceptance{app=~\"$app\"})",
          "legendFormat": "{{app}} acceptance quota",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (app) (sockudo_push_quota_consumed_delivery{app=~\"$app\"})",
          "legendFormat": "{{app}} delivery consumed",
          "refId": "D"
        }
      ],
      "title": "Throttling And Quotas",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "panels": [],
