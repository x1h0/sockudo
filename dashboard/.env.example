# Dashboard API — copy relevant vars into repo root .env

# Session signing (required)
DASHBOARD_SESSION_SECRET=change-me-use-openssl-rand-base64-32
DASHBOARD_API_PORT=3460
DASHBOARD_CORS_ORIGIN=http://localhost:5174

# Optional first-run admin seed (Docker / startup)
# DASHBOARD_SEED_EMAIL=admin@sockudo.local
# DASHBOARD_SEED_PASSWORD=change-me-now
# DASHBOARD_SEED_NAME=Administrator

# Dashboard users DB (auto-derived from APP_MANAGER_DRIVER)
# Uses same mysql/pgsql DB as Sockudo apps; falls back to sqlite when APP_MANAGER_DRIVER=dynamodb
# DASHBOARD_DATABASE_DRIVER=sqlite
# DASHBOARD_SQLITE_PATH=./dashboard/api/data/dashboard.sqlite

# Sockudo app store (not memory)
APP_MANAGER_DRIVER=pgsql

# Sockudo upstream (internal)
SOCKUDO_HTTP_URL=http://127.0.0.1:6001
SOCKUDO_METRICS_URL=http://127.0.0.1:9601

# PostgreSQL (when APP_MANAGER_DRIVER=pgsql)
DATABASE_POSTGRES_HOST=127.0.0.1
DATABASE_POSTGRES_PORT=5432
DATABASE_POSTGRES_USERNAME=sockudo
DATABASE_POSTGRES_PASSWORD=sockudo123
DATABASE_POSTGRES_DATABASE=sockudo
DATABASE_POSTGRES_TABLE_NAME=applications

# MySQL (when APP_MANAGER_DRIVER=mysql)
# DATABASE_MYSQL_HOST=127.0.0.1
# DATABASE_MYSQL_PORT=3306
# DATABASE_MYSQL_USERNAME=sockudo
# DATABASE_MYSQL_PASSWORD=
# DATABASE_MYSQL_DATABASE=sockudo
# DATABASE_MYSQL_TABLE_NAME=applications

# DynamoDB (when APP_MANAGER_DRIVER=dynamodb)
# DATABASE_DYNAMODB_REGION=us-east-1
# DATABASE_DYNAMODB_TABLE_NAME=sockudo-applications

# Bootstrap first admin (CLI only — not used at runtime)
# bun run seed:admin admin@sockudo.local 'your-secure-password' 'Admin'
